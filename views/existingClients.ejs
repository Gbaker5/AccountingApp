<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Existing Clients</title>
</head>
<body>
    <h1>Existing Clients</h1>

    <nav>
        <ul>
            <li><a href="/newClient">New Client</a></li>
             <li><a href="/profile">Profile</a></li>
        </ul>
    </nav>

    <div>
        <h2>My Clients</h2>

         <ul>
            <%for(let i=0; i < myClients.length; i++){%>
                <li><a href="/clientPage/<%=myClients[i]._id%>"><%=myClients[i].firstName%> <%=myClients[i].lastName%></a></li>
            <%}%>
        </ul>
    </div>
</body>
</html>